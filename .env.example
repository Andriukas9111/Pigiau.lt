# NordWash environment variables
# Copy this file to ".env.local" for local dev, and add the same keys in
# Vercel → Project → Settings → Environment Variables for production.
#
# Until RESEND_API_KEY and CONTACT_TO are set, the contact & booking forms
# stay honest: instead of a false "we got your message", visitors are shown a
# graceful fallback asking them to call or email us directly. Set these to
# turn on real email delivery.

# Resend API key — create one free at https://resend.com (Dashboard → API Keys)
RESEND_API_KEY=

# Inbox that should receive contact messages & new bookings
CONTACT_TO=hello@nordwash.lt

# Verified sender. While testing you may use Resend's shared sender:
#   "NordWash <onboarding@resend.dev>"
# For production, verify the nordwash.lt domain in Resend and use e.g.:
#   "NordWash <noreply@nordwash.lt>"
CONTACT_FROM=NordWash <onboarding@resend.dev>
